<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Noor Tons</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="container">

<!-- HEADER -->
<header class="header">
  <div class="logo">NOOR TONES</div>

  <div class="social">
    <a href="#">📺</a>
    <a href="#">📸</a>
  </div>
</header>

<!-- SEARCH -->
<div class="search-box">
  <input type="text" placeholder="Search ringtone...">
</div>

<!-- TAGS -->
<div class="tags">
  <span>Naat</span>
  <span>Nasheed</span>
  <span>Trending</span>
  <span>iPhone</span>
  <span>Notification</span>
</div>

<!-- CARDS -->
<div id="list"></div>

</div>

<script>

// 100 CARDS
const container = document.getElementById("list");

for(let i=1;i<=100;i++){

  container.innerHTML += `
  <div class="card">

    <div class="play" onclick="playAudio(${i})">▶</div>

    <div class="info">
      Ringtone ${i}
      <audio id="audio${i}" src="tone1.mp3"></audio>
    </div>

    <div class="actions">
      <button onclick="openPage(${i})">⬇</button>
      <button>🔗</button>
      <button>❤️</button>
    </div>

  </div>
  `;

  // ADS after 6
  if(i%6===0){
    container.innerHTML += `<div class="ad">Ad Space</div>`;
  }
}

// PLAY
function playAudio(i){
  let audio = document.getElementById("audio"+i);
  audio.paused ? audio.play() : audio.pause();
}

// OPEN PAGE
function openPage(id){
  alert("Next page open hoga (abhi simple version)");
}

</script>

</body>
</html>
